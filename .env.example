# 高考志愿填报AI分析工具 - 环境变量配置

# 应用配置
APP_NAME="高考志愿填报AI分析工具"
APP_VERSION="0.1.0"
DEBUG=false

# ==================== 小米 MiMo API 配置 ====================
# API 地址（小米MiMo兼容OpenAI格式）
LLM_API_BASE_URL=https://api.xiaomimimo.com/v1

# API Key - 在 https://platform.xiaomimimo.com/#/console/api-keys 获取
LLM_API_KEY=你的API_KEY填这里

# 模型名称
LLM_MODEL=mimo-v2.5-pro

# 生成参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=8000

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
